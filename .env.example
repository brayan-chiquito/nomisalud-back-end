# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME="NomiSalud API"
APP_VERSION="0.1.0"
DEBUG=false
ENVIRONMENT=production

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_strong_password
POSTGRES_DB=nomisalud_db

# ─── Seguridad ────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["https://your-frontend-domain.com"]

# ─── Carga de archivos (incapacidades) ────────────────────────────────────────
UPLOAD_STORAGE_DIR=var/uploads
MAX_UPLOAD_BYTES=10485760

# ─── Google Gemini (API key) ─────────────────────────────────────────────────
# Clave de la API de Gemini (Google AI). Créala en Google AI Studio:
#   https://aistudio.google.com/apikey
#
# Formato en .env (sin espacios alrededor del =):
#   GEMINI_API_KEY=AIzaSy...tu_clave...
#
# No uses comillas salvo que el valor lleve espacios (no es el caso habitual).
# Nunca subas esta clave a git: solo en .env local o en secretos del orquestador (Docker/K8s/CI).
GEMINI_API_KEY=AIzaSy_reemplaza_con_tu_clave
# Modelo por defecto en Settings (otros usos futuros). El extractor usa fijo gemini-2.5-flash.
GEMINI_MODEL=gemini-2.5-flash
# Reintentos ante errores de red / rate limit / 5xx
GEMINI_EXTRACTION_MAX_ATTEMPTS=4
GEMINI_EXTRACTION_BACKOFF_BASE_SECONDS=1.0
GEMINI_HTTP_TIMEOUT_SECONDS=120
