# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME="NomiSalud API"
APP_VERSION="0.1.0"
DEBUG=false
ENVIRONMENT=production

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_strong_password
POSTGRES_DB=nomisalud_db

# ─── Seguridad ────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["https://your-frontend-domain.com"]

# ─── Carga de archivos (incapacidades) ────────────────────────────────────────
UPLOAD_STORAGE_DIR=var/uploads
MAX_UPLOAD_BYTES=10485760
# Tamaño de página del listado GET /incapacidades
INCAPACIDADES_PAGE_SIZE=20

# ─── Google Gemini (API key) ─────────────────────────────────────────────────
# Clave de la API de Gemini (Google AI). Créala en Google AI Studio:
#   https://aistudio.google.com/apikey
#
# Formato en .env (sin espacios alrededor del =):
#   GEMINI_API_KEY=AIzaSy...tu_clave...
#
# No uses comillas salvo que el valor lleve espacios (no es el caso habitual).
# Nunca subas esta clave a git: solo en .env local o en secretos del orquestador (Docker/K8s/CI).
GEMINI_API_KEY=AIzaSy_reemplaza_con_tu_clave
# Modelo por defecto en Settings (otros usos futuros). El extractor usa fijo gemini-2.5-flash.
GEMINI_MODEL=gemini-2.5-flash
# Reintentos ante errores de red / rate limit / 5xx
GEMINI_EXTRACTION_MAX_ATTEMPTS=4
GEMINI_EXTRACTION_BACKOFF_BASE_SECONDS=1.0
GEMINI_HTTP_TIMEOUT_SECONDS=120

# Tesseract OCR (SCRUM-165; en Docker el binario viene en la imagen)
# TESSERACT_CMD=
TESSERACT_LANG=spa+eng
OCR_CONTRAST_FACTOR=2.0
OCR_PDF_RENDER_DPI=200
OCR_MIN_CHARS_PDF_NATIVO=40

# ─── Job diario de vencimientos (SCRUM-180) ───────────────────────────────────
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=America/Bogota
SCHEDULER_CRON_HOUR=7
SCHEDULER_CRON_MINUTE=0

# ─── SMTP alertas por correo (SCRUM-181) ──────────────────────────────────────
MAIL_ENABLED=false
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=alertas@nomisalud.com
MAIL_STARTTLS=true
MAIL_SSL_TLS=false
MAIL_VALIDATE_CERTS=true
# Destinatarios RRHH (separados por coma)
MAIL_ALERT_RECIPIENTS=coordinador.rrhh@nomisalud.com,auxiliar.rrhh@nomisalud.com

# ─── Deduplicación de alertas (SCRUM-182) ─────────────────────────────────────
ALERTAS_DEDUP_DIAS=7
